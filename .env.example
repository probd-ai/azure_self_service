# ═══════════════════════════════════════════════════════════════════════════════
# OPTION 1 — Coxy (GitHub Copilot proxy) — recommended for POC / free tier
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Start Coxy:  docker run -p 3000:3000 ghcr.io/coxy-proxy/coxy:latest
# 2. Open http://localhost:3000 → sign in with GitHub → set a default token
# 3. Set USE_COXY=true below — no paid API key needed!
USE_COXY=true
COXY_BASE_URL=http://localhost:3000/api
COXY_MODEL=gpt-4o
# Use _ if you set a default token in the Coxy UI (http://localhost:3000/api-keys)
# Or paste your actual token here directly
COXY_API_KEY=_

# ═══════════════════════════════════════════════════════════════════════════════
# OPTION 2 — Azure OpenAI
# ═══════════════════════════════════════════════════════════════════════════════
USE_AZURE_OPENAI=false
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ═══════════════════════════════════════════════════════════════════════════════
# OPTION 3 — Standard OpenAI
# ═══════════════════════════════════════════════════════════════════════════════
# USE_COXY=false
# USE_AZURE_OPENAI=false
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Paths ──────────────────────────────────────────────────────────────────────
TF_TEMPLATES_BASE_PATH=./terraform

# ═══════════════════════════════════════════════════════════════════════════════
# NOTE: Phase 2 (automated deployment) variables have been intentionally omitted.
# See DEPLOYMENT_CHALLENGES.md for a full risk analysis before implementing Phase 2.
# ═══════════════════════════════════════════════════════════════════════════════
